<?xml version="1.0" encoding="utf-8"?>
<project>

	<!-- ========================= APPLICATION ========================= -->

	<app 
		title="Friday Night Funkin': CoreX Engine"
		file="CoreXEngine"
		packageName="me.funkin.corex"
		package="me.funkin.corex"
		main="Main"
		version="0.3.0"
		company="Brenninho"
	/>

	<!-- Mobile Custom Title -->
	<app 
		if="mobile"
		title="FNF: CoreX"
	/>

	<!-- Switch -->
	<set name="APP_ID" value="0x0100f6c013bbc000" />

	<!-- ========================= CORE ========================= -->

	<haxedef name="LINC_LUA_RELATIVE_DYNAMIC_LIB"/>

	<app preloader="flixel.system.FlxPreloader"/>

	<set name="SWF_VERSION" value="11.8"/>

	<!-- ========================= ENGINE FEATURES ========================= -->

	<define name="MODS_ALLOWED" if="desktop || mobile"/>
	<define name="HSCRIPT_ALLOWED" if="desktop || mobile"/>
	<define name="LUA_ALLOWED" if="desktop || mobile"/>
	<define name="VIDEOS_ALLOWED" if="desktop || mobile" unless="32bits || hl || NOVIDEO || rpi"/>
	<define name="ACHIEVEMENTS_ALLOWED"/>
	<define name="COPYSTATE_ALLOWED" if="MODS_ALLOWED mobile"/>
	<define name="PSYCH_WATERMARKS"/>
	<define name="DISCORD_ALLOWED" if="desktop"/>
	<define name="SHARE_MOBILE_FILES" if="mobile"/>

	<!-- CoreX Features -->
	<define name="COREX_ENGINE"/>
	<define name="COREX_SHADERS"/>
	<define name="COREX_OPTIMIZED"/>
	<define name="COREX_MOBILE_UI"/>
	<define name="COREX_FAST_LOADING"/>
	<define name="COREX_VIDEO_SYSTEM"/>
	<define name="COREX_MEMORY_OPT"/>

	<section if="officialBuild">
		<define name="TITLE_SCREEN_EASTER_EGG"/>
	</section>

	<!-- ========================= WINDOWS ========================= -->

	<window
		width="1280"
		height="720"
		background="#000000"
		hardware="true"
		vsync="false"
	/>

	<window if="html5"
		resizable="true"
	/>

	<window if="desktop"
		orientation="landscape"
		fullscreen="false"
		resizable="true"
		borderless="false"
		allow-high-dpi="true"
		vsync="false"
	/>

	<window if="mobile"
		orientation="landscape"
		fullscreen="true"
		resizable="false"
		allow-shaders="true"
		require-shaders="true"
		allow-high-dpi="true"
		vsync="false"
	/>

	<window if="switch"
		orientation="landscape"
		fullscreen="true"
		width="0"
		height="0"
		resizable="true"
	/>

	<!-- ========================= BUILD PATHS ========================= -->

	<set name="BUILD_DIR" value="export/debug" if="debug"/>
	<set name="BUILD_DIR" value="export/release" unless="debug"/>
	<set name="BUILD_DIR" value="export/32bit" if="32bits"/>

	<classpath name="source"/>

	<!-- ========================= ASSETS ========================= -->

	<assets path="assets/fonts"/>

	<assets path="assets/shared" exclude="*.ogg" if="web"/>
	<assets path="assets/shared" exclude="*.mp3" unless="web"/>

	<assets path="assets/shared/mobile"
		library="mobile"
		if="mobile"
	/>

	<assets path="assets/videos"
		library="videos"
		if="VIDEOS_ALLOWED"
	/>

	<assets path="assets/songs"
		library="songs"
		exclude="*.ogg"
		if="web"
	/>

	<assets path="assets/songs"
		library="songs"
		exclude="*.mp3"
		unless="web"
	/>

	<assets path="assets/week_assets"
		library="week_assets"
		rename="assets"
		exclude="*.ogg"
		if="web"
	/>

	<assets path="assets/week_assets"
		library="week_assets"
		rename="assets"
		exclude="*.mp3"
		unless="web"
	/>

	<section if="TITLE_SCREEN_EASTER_EGG">
		<assets path="assets/secrets"
			rename="assets/shared"
			exclude="*.ogg"
			if="web"
		/>

		<assets path="assets/secrets"
			rename="assets/shared"
			exclude="*.mp3"
			unless="web"
		/>
	</section>

	<section if="MODS_ALLOWED">
		<assets path="example_mods"
			rename="mods"
			embed="false"
		/>
	</section>

	<assets path="art/readme.txt"
		rename="do NOT readme.txt"
		unless="mobile"
	/>

	<!-- ========================= LIBRARIES ========================= -->

	<haxelib name="flixel"/>
	<haxelib name="flixel-ui"/>
	<haxelib name="flixel-addons"/>
	<haxelib name="tjson"/>
	<haxelib name="flxanimate"/>

	<!-- Lua -->
	<haxelib name="linc_luajit" if="LUA_ALLOWED"/>

	<!-- Script -->
	<haxelib name="SScript" if="HSCRIPT_ALLOWED"/>

	<!-- Video -->
	<haxelib name="hxCodec" if="VIDEOS_ALLOWED"/>

	<!-- Discord -->
	<haxelib name="hxdiscord_rpc" if="DISCORD_ALLOWED"/>

	<!-- Debug -->
	<haxelib name="hxcpp-debug-server" if="debug"/>

	<!-- ========================= PERFORMANCE ========================= -->

	<haxedef name="FLX_NO_FOCUS_LOST_SCREEN"/>
	<haxedef name="FLX_NO_DEBUG" unless="debug"/>
	<haxedef name="NAPE_RELEASE_BUILD" unless="debug"/>
	<haxedef name="HXC_DEBUG_TRACE" if="debug"/>
	<haxedef name="HXC_LIBVLC_LOGGING" if="VIDEOS_ALLOWED debug"/>
	<haxedef name="DISCORD_DISABLE_IO_THREAD" if="hxdiscord_rpc"/>
	<haxedef name="NO_PRECOMPILED_HEADERS" if="linux"/>
	<haxedef name="loop_unroll_max_cost" value="25"/>
	<haxedef name="DISABLED_MACRO_SUPERLATIVE" if="android"/>
	<haxedef name="no-deprecation-warnings"/>

	<!-- Mobile Optimization -->
	<haxedef name="HXCPP_M64" if="android"/>
	<haxedef name="HXCPP_OPTIMIZE_LINK"/>
	<haxedef name="HXCPP_GC_BIG_BLOCKS"/>
	<haxedef name="HXCPP_CHECK_POINTER"/>
	<haxedef name="HXCPP_STACK_LINE"/>
	<haxedef name="HXCPP_STACK_TRACE"/>
	<haxedef name="HXCPP_CATCH_SEGV"/>

	<!-- ========================= MACROS ========================= -->

	<haxeflag name="--macro" value="allowPackage('flash')"/>
	<haxeflag name="--macro" value="include('my.pack')"/>

	<!-- ========================= LIBRARIES LOAD ========================= -->

	<library name="videos" preload="true" if="VIDEOS_ALLOWED"/>
	<library name="songs" preload="true"/>
	<library name="week_assets" preload="true"/>

	<!-- ========================= ANDROID ========================= -->

	<certificate
		path="key.keystore"
		password="psychengine"
		alias="psychport"
		alias-password="psychengine"
		if="android"
		unless="debug"
	/>

	<!-- ========================= APPLE ========================= -->

	<config:ios category_type="public.app-category.music-games"/>
	<config:mac category_type="public.app-category.music-games"/>

	<!-- ========================= 32 BITS ========================= -->

	<app path="export\32bit\windows\bin" if="32bits"/>

	<!-- ========================= ICONS ========================= -->

	<assets path="art/iconOG.png"
		rename="icon.png"
		if="linux"
	/>

	<icon path="art/icon16.png" size="16"/>
	<icon path="art/icon32.png" size="32"/>
	<icon path="art/icon64.png" size="64"/>
	<icon path="art/iconOG.png"/>

</project>